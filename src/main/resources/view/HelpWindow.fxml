<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.stage.Stage?>

<fx:root resizable="true" minWidth="600" minHeight="400" title="Help" type="javafx.stage.Stage" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <scene>
    <Scene>
      <stylesheets>
        <URL value="@HelpWindow.css" />
      </stylesheets>

      <VBox alignment="TOP_LEFT" fx:id="helpMessageContainer" spacing="10">
        <children>
          <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
              <Label fx:id="helpMessage" text="Label" wrapText="true" maxWidth="550">
              <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
              </padding>
              </Label>
            </content>
          </ScrollPane>

          <HBox alignment="CENTER_RIGHT" spacing="10">
            <children>
              <Button fx:id="copyButton" mnemonicParsing="false" onAction="#copyUrl" text="Copy URL">
              </Button>
            </children>
            <HBox.margin>
              <Insets bottom="10.0" left="10.0" right="10.0" top="5.0" />
            </HBox.margin>
          </HBox>
        </children>
        <opaqueInsets>
          <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
        </opaqueInsets>
        <padding>
          <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
        </padding>
      </VBox>
    </Scene>
  </scene>
</fx:root>
